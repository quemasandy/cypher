{
  "name": "cypher",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "cypher",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=20.0.0"
      }
    },
    "apps/cli": {
      "name": "@cipher/cli",
      "version": "0.1.0",
      "dependencies": {
        "@cipher/application": "file:../../packages/application",
        "@cipher/infra": "file:../../packages/infra"
      }
    },
    "node_modules/@cipher/application": {
      "resolved": "packages/application",
      "link": true
    },
    "node_modules/@cipher/cli": {
      "resolved": "apps/cli",
      "link": true
    },
    "node_modules/@cipher/contracts": {
      "resolved": "packages/contracts",
      "link": true
    },
    "node_modules/@cipher/domain": {
      "resolved": "packages/domain",
      "link": true
    },
    "node_modules/@cipher/infra": {
      "resolved": "packages/infra",
      "link": true
    },
    "packages/application": {
      "name": "@cipher/application",
      "version": "0.1.0",
      "dependencies": {
        "@cipher/contracts": "file:../contracts",
        "@cipher/domain": "file:../domain"
      }
    },
    "packages/contracts": {
      "name": "@cipher/contracts",
      "version": "0.1.0"
    },
    "packages/domain": {
      "name": "@cipher/domain",
      "version": "0.1.0"
    },
    "packages/infra": {
      "name": "@cipher/infra",
      "version": "0.1.0",
      "dependencies": {
        "@cipher/contracts": "file:../contracts",
        "@cipher/domain": "file:../domain"
      }
    }
  }
}
