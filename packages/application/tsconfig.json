// Este archivo compila la capa de aplicacion.
// Se declara aparte porque application depende de domain y contracts, y debe
// emitirse como paquete propio sin mezclar sus artefactos con otras capas.
{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "references": [
    { "path": "../domain" },
    { "path": "../contracts" }
  ]
}
